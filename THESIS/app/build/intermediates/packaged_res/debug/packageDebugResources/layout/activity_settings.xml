<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollSettings"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvSettingsTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#111827"
                android:textSize="30sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvDailyLimitLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Daily limit (10-120 mins)"
                android:textColor="#111827"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/tvSettingsTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvDailyLimitValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="60 min"
                android:textColor="#534AB7"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/tvDailyLimitLabel"
                app:layout_constraintStart_toStartOf="parent" />

            <SeekBar
                android:id="@+id/seekDailyLimit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:max="110"
                android:progress="50"
                app:layout_constraintTop_toBottomOf="@id/tvDailyLimitValue"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvCooldownLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Cooldown duration (5-60 mins)"
                android:textColor="#111827"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/seekDailyLimit"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvCooldownValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="10 min"
                android:textColor="#534AB7"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/tvCooldownLabel"
                app:layout_constraintStart_toStartOf="parent" />

            <SeekBar
                android:id="@+id/seekCooldown"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:max="55"
                android:progress="5"
                app:layout_constraintTop_toBottomOf="@id/tvCooldownValue"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardToggles"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/seekCooldown"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchGentleReminders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Gentle reminders" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchLimitAlert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Limit reached alert" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchStreakNotifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Streak notifications" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchWeeklySummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Weekly summary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveSettings"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#534AB7"
                android:text="Save Settings"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:cornerRadius="12dp"
                app:layout_constraintTop_toBottomOf="@id/cardToggles"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                app:layout_constraintTop_toBottomOf="@id/btnSaveSettings"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="#534AB7"
        app:itemTextColor="#534AB7"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
