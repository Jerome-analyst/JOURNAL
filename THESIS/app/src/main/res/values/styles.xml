<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Keyboard key for the word game — dark theme -->
    <style name="GameKeyStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:textColor">#E8E8F8</item>
        <item name="backgroundTint">#2A2A45</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">#534AB7</item>
    </style>

    <!-- Letter answer slot in the game -->
    <style name="SlotStyle">
        <item name="android:layout_width">52dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/bg_slot</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#E8E8F8</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Tappable scrambled letter tile -->
    <style name="TileStyle">
        <item name="android:layout_width">58dp</item>
        <item name="android:layout_height">66dp</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/bg_tile</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#E8E8F8</item>
        <item name="android:textSize">26sp</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

</resources>
